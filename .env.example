NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Autonomous background execution (Phase 21) — app/api/cron/process-jobs
# only. Never referenced by any browser-reachable code. SUPABASE_SERVICE_
# ROLE_KEY is the one deliberate exception to this app's "anon key + RLS
# everywhere" rule, since a scheduled job has no user session to run as;
# CRON_SECRET is a random string you generate yourself and also configure
# as the Authorization: Bearer header Vercel Cron (or any external
# scheduler) sends — without a matching header the route returns 401
# before ever touching the database.
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=

# Model providers (lib/providers) — configure whichever your agents use.
# Agents pick a provider per execution; none of these are required to
# build or run the app, only to actually execute an agent capability.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Local model provider targets an Ollama-compatible HTTP server.
LOCAL_MODEL_URL=http://localhost:11434
LOCAL_MODEL_NAME=

# Gmail (lib/integrations/gmail) — required only for the Outreach Agent's
# real send/reply-check capability. Create an OAuth 2.0 Client ID (type
# "Web application") in Google Cloud Console, enable the Gmail API, and
# add GOOGLE_REDIRECT_URI as an authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/gmail/callback

# HubSpot and Hunter.io need no server-side config — an organization
# manager connects both directly from an organization's Integrations tab
# (a HubSpot Private App access token, and a Hunter.io API key).

# Billing (Phase 24) — lib/stripe.ts, app/api/billing/*. Create two
# recurring Prices in the Stripe dashboard (Standard/Growth), then a
# webhook endpoint pointed at https://<your-domain>/api/billing/webhook
# subscribed to: checkout.session.completed, customer.subscription.created,
# customer.subscription.updated, customer.subscription.deleted,
# invoice.payment_failed. Every organization gets a real 14-day trial
# with no card required the moment it's created — none of this is needed
# just to evaluate the product, only to actually charge someone.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STANDARD=
STRIPE_PRICE_ID_GROWTH=
STRIPE_TRIAL_DAYS=14

# Production monitoring (Phase 24) — all optional, all safe to leave
# unset (each just no-ops rather than breaking anything).
# NEXT_PUBLIC_SENTRY_DSN: create a project at sentry.io, paste its DSN
# here — wires up real error tracking for both server and client code
# (instrumentation.ts, instrumentation-client.ts, sentry.*.config.ts).
# SENTRY_ORG/SENTRY_PROJECT + SENTRY_AUTH_TOKEN (a Sentry auth token) are
# only needed if you also want source maps uploaded on build.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ALERT_WEBHOOK_URL: any webhook-shaped receiver (a Slack incoming
# webhook URL is the simplest) — the cron worker and the Stripe webhook
# handler both POST a plain-JSON alert here on a real failure
# (lib/alerting.ts). Left unset, alerting silently no-ops; the Error
# Center (/admin/support) remains the pull-based fallback either way.
ALERT_WEBHOOK_URL=
